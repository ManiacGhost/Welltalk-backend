{
  "info": {
    "_postman_id": "newsletter-api-collection",
    "name": "Welltalk Newsletter API",
    "description": "Complete Postman collection for Newsletter Management API testing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Newsletter - Public",
      "item": [
        {
          "name": "Subscribe to Newsletter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"preferences\": {\n    \"frequency\": \"weekly\",\n    \"categories\": [\"wellness\", \"fitness\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribe"]
            },
            "description": "Subscribe a new user to the newsletter with email and optional preferences"
          },
          "response": []
        },
        {
          "name": "Subscribe with Minimal Info",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"simple@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribe",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribe"]
            },
            "description": "Subscribe with just an email address"
          },
          "response": []
        },
        {
          "name": "Get Subscriber by Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscriber/newuser@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscriber", "newuser@example.com"]
            },
            "description": "Retrieve subscriber information by email address"
          },
          "response": []
        },
        {
          "name": "Unsubscribe from Newsletter",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Receiving too many emails\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/unsubscribe/newuser@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "unsubscribe", "newuser@example.com"]
            },
            "description": "Unsubscribe a user from the newsletter with optional reason"
          },
          "response": []
        },
        {
          "name": "Unsubscribe without Reason",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/unsubscribe/newuser@example.com",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "unsubscribe", "newuser@example.com"]
            },
            "description": "Unsubscribe without providing a reason"
          },
          "response": []
        },
        {
          "name": "Update Subscriber Preferences",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"preferences\": {\n    \"frequency\": \"bi-weekly\",\n    \"categories\": [\"fitness\", \"meditation\", \"nutrition\"]\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscriber/newuser@example.com/preferences",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscriber", "newuser@example.com", "preferences"]
            },
            "description": "Update subscription preferences including frequency and content categories"
          },
          "response": []
        }
      ]

    {
      "name": "Newsletter - Admin",
      "item": [
        {
          "name": "Get All Subscribers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}",
                "disabled": false
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribers?page=1&limit=50&status=subscribed",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribers"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "50"
                },
                {
                  "key": "status",
                  "value": "subscribed"
                }
              ]
            },
            "description": "Get paginated list of all newsletter subscribers with optional filters"
          },
          "response": []
        },
        {
          "name": "Get Subscribers - Page 1",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribers?page=1&limit=20",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribers"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "20"
                }
              ]
            },
            "description": "Get first page of subscribers (20 per page)"
          },
          "response": []
        },
        {
          "name": "Get Unsubscribed Subscribers",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/subscribers?status=unsubscribed",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "subscribers"],
              "query": [
                {
                  "key": "status",
                  "value": "unsubscribed"
                }
              ]
            },
            "description": "Get all unsubscribed users"
          },
          "response": []
        },
        {
          "name": "Send Newsletter to All Subscribers",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Welltalk Weekly - Your Weekly Wellness Guide\",\n  \"htmlContent\": \"<html><body><h1>Welcome to Welltalk Weekly!</h1><p>This week we're featuring:</p><ul><li>New meditation techniques</li><li>Fitness tips for beginners</li><li>Nutrition guide</li></ul><p>Thanks for being part of our wellness community!</p></body></html>\",\n  \"textContent\": \"Welcome to Welltalk Weekly! This week we're featuring: New meditation techniques, Fitness tips for beginners, Nutrition guide.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/send",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "send"]
            },
            "description": "Send newsletter to all active subscribers with HTML and optional plain text content"
          },
          "response": []
        },
        {
          "name": "Send Simple Newsletter",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"subject\": \"Quick Update from Welltalk\",\n  \"htmlContent\": \"<p>Here's what's new this week...</p>\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/send",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "send"]
            },
            "description": "Send newsletter with minimal required fields"
          },
          "response": []
        },
        {
          "name": "Get Newsletter Statistics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/newsletter/stats",
              "host": ["{{base_url}}"],
              "path": ["api", "v1", "newsletter", "stats"]
            },
            "description": "Get comprehensive newsletter statistics including subscriber counts, email metrics, and engagement rates"
          },
          "response": []
        }
      ]
